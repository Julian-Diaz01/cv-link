{
  "hosting": {
    "headers": [
      {
        "source": "**/*.@(js)",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/javascript"
          }
        ]
      }
    ],
    "site": "juliandiaz",
    "public": "build",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/studio", "destination": "/studio/index.html" },
      { "source": "/studio/**", "destination": "/studio/index.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
